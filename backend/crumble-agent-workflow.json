        "jsCode": "// 1. Get the text from the Gemini Extractor\nconst rawText = $node[\"Message a model\"].json.content.parts[0].text;\n\n// 2. Parse it into a real Javascript object\nconst data = JSON.parse(rawText);\n\n// 3. Define your business logic (Price List)\nconst prices = {\n  \"hazelnut cookie\": 500,\n  \"chocolate chip\": 400,\n  \"lotus biscoff\": 600\n};\n\n// 4. Calculate\nconst item = data.item.toLowerCase();\nconst quantity = data.quantity;\nconst unitPrice = prices[item] || 500; // Default to 500 if item not found\nconst totalBill = quantity * unitPrice;\n\n// 5. Output the facts for the next node\nreturn {\n  customer_item: item,\n  customer_quantity: quantity,\n  bill_total: totalBill,\n  currency: \"Rs.\"\n};"
