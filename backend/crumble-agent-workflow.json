    {
      "parameters": {
        "jsCode": "let items = $input.all();\n\n// 1. SAFETY CATCH: If the Google Sheet is empty (brand new user),\n// n8n passes an empty object. We catch it here so the bot doesn't crash.\nif (items.length === 0 || Object.keys(items[0].json).length === 0 || !items[0].json.timestamp) {\n    return [{ json: { historyString: \"No previous conversation history. This is a new user.\" } }];\n}\n\n// 2. SORT: Arrange by timestamp descending (newest messages first)\nitems.sort((a, b) => new Date(b.json.timestamp) - new Date(a.json.timestamp));\n\n// 3. LIMIT: Keep only the most recent 6 messages to save AI token limits\nlet limited = items.slice(0, 6);\n\n// 4. FORMAT: Stitch them into a clean script for Gemini.\n// We reverse it so it reads chronologically top-to-bottom.\nlet history = limited.reverse().map(item => {\n    let role = item.json.role ? item.json.role.toUpperCase() : \"UNKNOWN\";\n    let text = item.json.text ? item.json.text : \"\";\n    return `${role}: ${text}`;\n}).join('\\n');\n\n// 5. OUTPUT: Pass the clean string to the next node\nreturn [{ json: { historyString: history } }];"
      },
